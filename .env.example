# Cuckoo API 配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# Cuckoo API 连接配置
# ============================================

# Cuckoo API 地址 (强烈建议使用 HTTPS)
# 开发环境示例: http://192.168.22.176:1337
# 生产环境示例: https://cuckoo.example.com:1337
CUCKOO_API_URL=https://192.168.22.176:1337

# Cuckoo API 认证令牌
# 请将 your_token_here 替换为实际的 API Token
CUCKOO_API_TOKEN=your_token_here

# ============================================
# SSL/TLS 配置
# ============================================

# 是否允许自签名证书（仅用于开发/测试环境）
# 可选值: true, false, yes, no, 1, 0
# 警告: 生产环境必须设置为 false
# 默认值: false
CUCKOO_ALLOW_SELF_SIGNED=false

# ============================================
# IOC 输出配置
# ============================================

# IOC 文件输出目录 (可选，默认为当前目录)
#
# Linux/macOS 示例:
# IOC_OUTPUT_DIR=/home/user/ioc_output
# IOC_OUTPUT_DIR=/var/lib/cuckoo/ioc
# IOC_OUTPUT_DIR=~/Documents/IOC
#
# Windows 示例:
# IOC_OUTPUT_DIR=C:\Users\YourName\Documents\IOC
# IOC_OUTPUT_DIR=D:\CuckooReports\IOC
#
# 相对路径示例（相对于脚本所在目录）:
# IOC_OUTPUT_DIR=./output
# IOC_OUTPUT_DIR=../reports/ioc
#
IOC_OUTPUT_DIR=/path/to/output/directory

# ============================================
# 配置说明
# ============================================
#
# 1. 环境变量加载方式:
#    - Linux/macOS: export $(cat .env | xargs)
#    - 或使用 python-dotenv 库自动加载
#
# 2. 路径格式注意事项:
#    - Linux/macOS 使用正斜杠: /path/to/dir
#    - Windows 使用反斜杠或正斜杠: C:\path\to\dir 或 C:/path/to/dir
#    - 路径包含空格时使用引号（在代码中自动处理）
#
# 3. 安全最佳实践:
#    - 不要提交包含真实凭证的 .env 文件到 Git
#    - 定期更换 API Token
#    - 生产环境使用 HTTPS 和有效的 SSL 证书
#    - 考虑使用专门的密钥管理服务
#
